# =========================================================================
# Job Scouting AL — environment variables
# Copy to .env.local and fill in. Never commit .env.local or .env*.
# =========================================================================

# ---- Supabase (Auth + Postgres) -----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google OAuth (Calendar sync) ---------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth-callback

# ---- SerpApi (job search) -----------------------------------------------
SERPAPI_KEY=

# ---- Anthropic (CV / cover / interview tips) ----------------------------
ANTHROPIC_API_KEY=

# ---- Resend (email notifications) ---------------------------------------
RESEND_API_KEY=
RESEND_FROM=canelo@job-scouting-al.vercel.app

# ---- Adzuna (aggregator fallback) ---------------------------------------
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- Admin endpoint (Cowork bridge) -------------------------------------
# generate with: openssl rand -hex 32
COWORK_ADMIN_TOKEN=

# ---- Vercel cron ---------------------------------------------------------
# generate with: openssl rand -hex 32
CRON_SECRET=

# ---- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Single-user lock ----------------------------------------------------
ALLOWED_EMAIL=canelopolymarket@gmail.com
